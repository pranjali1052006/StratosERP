# =============================================================
# StratosERP Backend - Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control
# =============================================================

# ----- Server -----
PORT=5000
NODE_ENV=development

# ----- Database (Prisma) -----
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:your_mysql_password_here@localhost:3306/StratosERP"

# ----- JWT Authentication -----
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=24h

# ----- MinIO Object Storage -----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_STUDY_MATERIALS=study-materials
MINIO_BUCKET_NOTICES=notices
MINIO_BUCKET_SUBMISSIONS=submissions

# ----- Google Gemini AI -----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ----- Admin Seed -----
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@tcetmumbai.in
