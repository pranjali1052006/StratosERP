    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "multer": "^2.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
