{
  "name": "@stratoserp/api",
  "version": "1.0.0",
  "private": true,
  "description": "StratosERP Phase-I Backend API",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
